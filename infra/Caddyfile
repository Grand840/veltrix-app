veltrix.io {
    reverse_proxy frontend:3000
}

api.veltrix.io {
    reverse_proxy api:8000
    header Access-Control-Allow-Origin "https://veltrix.io"
    header Access-Control-Allow-Methods "GET, POST, PATCH, DELETE, OPTIONS"
    header Access-Control-Allow-Headers "Authorization, Content-Type, X-Agent-Key"
}

:80 {
    @frontend path_regexp ^(?!/api).*
    @api      path /api/*
    reverse_proxy @frontend frontend:3000
    reverse_proxy @api      api:8000
}
